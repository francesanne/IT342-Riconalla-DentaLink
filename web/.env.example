# Set this to your deployed backend URL for production
VITE_API_BASE_URL=https://your-backend-url.onrender.com/api/v1

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials → Web client)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Google Maps API Key (from Google Cloud Console → APIs & Services → Credentials)
# Restrict this key to the Maps JavaScript API and your allowed referrer domains
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
