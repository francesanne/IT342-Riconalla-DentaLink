<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Main content ── -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_screen">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            android:elevation="4dp"
            app:title="Admin Dashboard"
            app:titleTextColor="@color/text_primary"
            app:navigationIconTint="@color/text_primary" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_padding"
                android:paddingEnd="@dimen/screen_padding"
                android:paddingTop="20dp"
                android:paddingBottom="32dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- ── Hero card ── -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_hero"
                    android:padding="@dimen/hero_padding"
                    android:layout_marginBottom="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Admin Dashboard"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Manage your dental clinic"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <!-- ── Stat row ── -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Total Appointments -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/bg_card"
                        android:padding="14dp"
                        android:elevation="2dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content">
                        <View
                            android:background="@drawable/bg_icon_stat_teal"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:id="@+id/tvTotalAppointments"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:text="Total Appts"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Pending Payments -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/bg_card"
                        android:padding="14dp"
                        android:elevation="2dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content">
                        <View
                            android:background="@drawable/bg_icon_stat_amber"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:id="@+id/tvPendingPayments"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/status_pending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:text="Pending Pay"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Confirmed -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/bg_card"
                        android:padding="14dp"
                        android:elevation="2dp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content">
                        <View
                            android:background="@drawable/bg_icon_stat_green"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:id="@+id/tvConfirmedAppointments"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/status_completed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:text="Confirmed"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ── Revenue card ── -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="20dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="24dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:text="Total Revenue"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvTotalRevenue"
                        android:text="P0.00"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- ── Quick Actions label ── -->
                <TextView
                    android:text="Quick Actions"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <!-- ── Nav buttons row 1 ── -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/btnAdminServices"
                        android:text="Services"
                        android:background="@drawable/bg_card"
                        android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:elevation="2dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:layout_width="0dp"
                        android:layout_height="64dp" />

                    <Button
                        android:id="@+id/btnAdminDentists"
                        android:text="Dentists"
                        android:background="@drawable/bg_card"
                        android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:elevation="2dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="64dp" />

                </LinearLayout>

                <!-- ── Nav buttons row 2 ── -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <Button
                        android:id="@+id/btnAdminAppointments"
                        android:text="Appointments"
                        android:background="@drawable/bg_card"
                        android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:elevation="2dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:layout_width="0dp"
                        android:layout_height="64dp" />

                    <Button
                        android:id="@+id/btnAdminPayments"
                        android:text="Payments"
                        android:background="@drawable/bg_card"
                        android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:elevation="2dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="64dp" />

                </LinearLayout>

                <!-- ── Recent Appointments ── -->
                <TextView
                    android:text="Recent Appointments"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <ListView
                    android:id="@+id/lvRecentAppointments"
                    android:divider="@null"
                    android:dividerHeight="0dp"
                    android:clipToPadding="false"
                    android:layout_width="match_parent"
                    android:layout_height="300dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ── Navigation Drawer ── -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        app:headerLayout="@layout/nav_header_admin"
        app:menu="@menu/nav_admin"
        app:itemTextColor="@color/text_primary"
        app:itemIconTint="@color/primary" />

</androidx.drawerlayout.widget.DrawerLayout>