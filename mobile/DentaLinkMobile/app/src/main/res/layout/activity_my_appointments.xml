<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        android:elevation="4dp"
        app:title="My Appointments"
        app:titleTextColor="@color/text_primary"
        app:navigationIconTint="@color/text_primary" />

    <!-- ── Filter chip bar ──
         Uses <TextView> (not <Button>) so that the android:background state selector
         and android:textColor state selector both work without Material3 interference. -->
    <HorizontalScrollView
        android:background="@color/surface"
        android:elevation="2dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnFilterAll"
                android:text="All"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/color_chip_text"
                android:background="@drawable/bg_filter_chip_selector"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginEnd="8dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp" />

            <TextView
                android:id="@+id/btnFilterConfirmed"
                android:text="Confirmed"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/color_chip_text"
                android:background="@drawable/bg_filter_chip_selector"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginEnd="8dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp" />

            <TextView
                android:id="@+id/btnFilterPending"
                android:text="Pending Payment"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/color_chip_text"
                android:background="@drawable/bg_filter_chip_selector"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginEnd="8dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp" />

            <TextView
                android:id="@+id/btnFilterCompleted"
                android:text="Completed"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/color_chip_text"
                android:background="@drawable/bg_filter_chip_selector"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginEnd="8dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp" />

            <TextView
                android:id="@+id/btnFilterCancelled"
                android:text="Cancelled"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/color_chip_text"
                android:background="@drawable/bg_filter_chip_selector"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Subtle divider below chips -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ── Empty state ── -->
    <TextView
        android:id="@+id/tvAppointmentsEmpty"
        android:text="No appointments found"
        android:textSize="15sp"
        android:textColor="@color/text_muted"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="72dp"
        android:layout_gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- ── Appointments list ── -->
    <ListView
        android:id="@+id/lvAppointments"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
