<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        android:elevation="4dp"
        app:title="My Appointments"
        app:titleTextColor="@color/text_primary"
        app:navigationIconTint="@color/text_primary" />

    <!-- Filter chips row -->
    <HorizontalScrollView
        android:background="@color/surface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnFilterAll"
                android:text="All"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp" />

            <Button
                android:id="@+id/btnFilterConfirmed"
                android:text="Confirmed"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                style="?attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btnFilterPending"
                android:text="Pending Payment"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                style="?attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btnFilterCompleted"
                android:text="Completed"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                style="?attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btnFilterCancelled"
                android:text="Cancelled"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                style="?attr/borderlessButtonStyle" />

        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvAppointmentsEmpty"
        android:text="No appointments found"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ListView
        android:id="@+id/lvAppointments"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
