<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <TextView android:text="Payment Records" android:textSize="22sp" android:textStyle="bold"
        android:layout_marginBottom="4dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content" />

    <TextView android:text="Records are updated automatically via PayMongo webhook"
        android:textSize="12sp" android:textColor="#888888"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content" />

    <TextView android:id="@+id/tvAdminPaymentsEmpty" android:text="No payment records yet"
        android:textColor="#AAAAAA" android:visibility="gone"
        android:layout_width="wrap_content" android:layout_height="wrap_content" />

    <ListView android:id="@+id/lvAdminPayments"
        android:divider="#EEEEEE" android:dividerHeight="1dp"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

</LinearLayout>