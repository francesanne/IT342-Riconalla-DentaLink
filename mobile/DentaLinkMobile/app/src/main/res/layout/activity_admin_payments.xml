<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        android:elevation="4dp"
        app:title="Payment Records"
        app:titleTextColor="@color/text_primary"
        app:navigationIconTint="@color/text_primary" />

    <TextView
        android:text="Records are updated automatically via PayMongo webhook"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:background="@color/surface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView android:id="@+id/tvAdminPaymentsEmpty"
        android:text="No payment records yet"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ListView android:id="@+id/lvAdminPayments"
        android:divider="@color/divider"
        android:dividerHeight="1dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
