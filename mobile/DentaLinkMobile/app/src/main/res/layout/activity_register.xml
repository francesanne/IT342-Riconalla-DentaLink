<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="40dp"
        android:paddingBottom="32dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ── Brand mark ── -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_logo_tooth"
            android:contentDescription="DentaLink logo"
            android:layout_marginBottom="16dp" />

        <!-- App name -->
        <TextView
            android:text="DentaLink"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:letterSpacing="0.01"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Subtitle -->
        <TextView
            android:text="Create your account"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="28dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- ── Form card ── -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:elevation="3dp"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- First Name label -->
            <TextView
                android:text="First Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- First Name input -->
            <EditText
                android:id="@+id/etFirstName"
                android:hint="@string/label_first_name"
                android:inputType="textPersonName"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="15sp"
                android:layout_marginBottom="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Last Name label -->
            <TextView
                android:text="Last Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Last Name input -->
            <EditText
                android:id="@+id/etLastName"
                android:hint="@string/label_last_name"
                android:inputType="textPersonName"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="15sp"
                android:layout_marginBottom="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Email label -->
            <TextView
                android:text="Email"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Email input -->
            <EditText
                android:id="@+id/etEmail"
                android:hint="@string/label_email"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="15sp"
                android:layout_marginBottom="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Password label -->
            <TextView
                android:text="Password"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Password input -->
            <EditText
                android:id="@+id/etPassword"
                android:hint="@string/label_password"
                android:inputType="textPassword"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="15sp"
                android:layout_marginBottom="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Confirm Password label -->
            <TextView
                android:text="Confirm Password"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Confirm Password input -->
            <EditText
                android:id="@+id/etConfirmPassword"
                android:hint="@string/label_confirm_password"
                android:inputType="textPassword"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="15sp"
                android:layout_marginBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Register CTA -->
            <Button
                android:id="@+id/btnRegister"
                android:text="@string/btn_register"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height" />

        </LinearLayout>

        <!-- ── Login link ── -->
        <Button
            android:id="@+id/btnGoLogin"
            android:text="@string/btn_go_login"
            style="?attr/borderlessButtonStyle"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

</ScrollView>
