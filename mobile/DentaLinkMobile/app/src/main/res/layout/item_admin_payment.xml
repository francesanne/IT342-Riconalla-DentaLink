<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:paddingStart="@dimen/card_padding"
    android:paddingEnd="@dimen/card_padding"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:layout_marginStart="@dimen/screen_padding"
    android:layout_marginEnd="@dimen/screen_padding"
    android:layout_marginBottom="@dimen/item_spacing"
    android:elevation="2dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Appt ID chip + Payment status badge -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvPayApptId"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_badge_confirmed"
            android:textColor="@color/badge_confirmed_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <View
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tvPayStatus"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Patient name -->
    <TextView
        android:id="@+id/tvPayPatientName"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Amount -->
    <TextView
        android:id="@+id/tvPayAmount"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Reference ID -->
    <TextView
        android:id="@+id/tvPayRef"
        android:textSize="11sp"
        android:textColor="@color/text_muted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</LinearLayout>