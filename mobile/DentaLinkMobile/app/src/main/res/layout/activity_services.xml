<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        android:elevation="4dp"
        app:title="Our Services"
        app:titleTextColor="@color/text_primary"
        app:navigationIconTint="@color/text_primary" />

    <!-- Subtitle strip -->
    <TextView
        android:text="Choose a service to book your appointment"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@color/surface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Subtle divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Loading state -->
    <ProgressBar
        android:id="@+id/progressServices"
        android:visibility="gone"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvServicesEmpty"
        android:text="No services available at the moment."
        android:textSize="15sp"
        android:textColor="@color/text_muted"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="72dp"
        android:layout_gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Services list -->
    <ListView
        android:id="@+id/lvServices"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
