<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Main content ── -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_screen">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            android:elevation="4dp"
            app:title="DentaLink"
            app:titleTextColor="@color/text_primary"
            app:navigationIconTint="@color/text_primary" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_padding"
                android:paddingEnd="@dimen/screen_padding"
                android:paddingTop="20dp"
                android:paddingBottom="32dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- ── Hero card ── -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_hero"
                    android:padding="@dimen/hero_padding"
                    android:layout_marginBottom="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:text="Welcome!"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Your dental appointment overview"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <!-- ── Stat cards ── -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Upcoming -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/bg_card"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:elevation="2dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/tvUpcomingCount"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:text="Upcoming"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Completed -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/bg_card"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:elevation="2dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/tvCompletedCount"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/status_completed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:text="Completed"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Pending Payment -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/bg_card"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:elevation="2dp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/tvPendingCount"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/status_pending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:text="Pending Pay"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ── Primary CTA ── -->
                <Button
                    android:id="@+id/btnBookAppointment"
                    android:text="Book Appointment"
                    style="@style/PrimaryButton"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height" />

                <!-- ── Secondary CTA — lighter teal, visually paired with primary ── -->
                <Button
                    android:id="@+id/btnClinicLocation"
                    android:text="Get Clinic Directions"
                    style="@style/SecondaryButton"
                    android:layout_marginBottom="28dp"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height" />

                <!-- ── Upcoming appointments section header ── -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Upcoming Appointments"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/tvViewAllAppointments"
                        android:text="View All →"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tvNoUpcoming"
                    android:text="No upcoming appointments"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- Upcoming appointment cards inflated here -->
                <LinearLayout
                    android:id="@+id/llUpcomingAppointments"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ── Navigation Drawer ── -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        app:headerLayout="@layout/nav_header_patient"
        app:menu="@menu/nav_patient"
        app:itemTextColor="@color/text_primary"
        app:itemIconTint="@color/primary" />

</androidx.drawerlayout.widget.DrawerLayout>
