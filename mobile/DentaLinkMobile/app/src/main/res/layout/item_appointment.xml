<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:paddingStart="@dimen/card_padding"
    android:paddingEnd="@dimen/card_padding"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:layout_marginStart="@dimen/screen_padding"
    android:layout_marginEnd="@dimen/screen_padding"
    android:layout_marginBottom="@dimen/item_spacing"
    android:elevation="2dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Top row: service name + status badge -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvApptServiceName"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvApptStatus"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/status_confirmed"
            android:background="@drawable/bg_status_badge"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Dentist name -->
    <TextView
        android:id="@+id/tvApptDentistName"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="3dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Date and time -->
    <TextView
        android:id="@+id/tvApptDatetime"
        android:textSize="12sp"
        android:textColor="@color/text_muted"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="10dp" />

    <!-- Payment footer row -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvApptPaymentStatus"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvCancelAppt"
            android:text="Cancel"
            android:textSize="11sp"
            android:textColor="@color/status_cancelled"
            android:textStyle="bold"
            android:background="@drawable/bg_status_badge"
            android:backgroundTint="@color/status_cancelled_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginEnd="6dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvPayNow"
            android:text="Tap to Pay"
            android:textSize="11sp"
            android:textColor="@color/badge_pending_text"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_pending"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

</LinearLayout>