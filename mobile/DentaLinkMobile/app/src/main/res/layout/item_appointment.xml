<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/card_padding"
    android:layout_marginBottom="@dimen/item_spacing"
    android:elevation="1dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Top row: service name + status badge -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginBottom="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvApptServiceName"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvApptStatus"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/status_confirmed"
            android:background="@drawable/bg_status_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Dentist name -->
    <TextView
        android:id="@+id/tvApptDentistName"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Date and time -->
    <TextView
        android:id="@+id/tvApptDatetime"
        android:textSize="12sp"
        android:textColor="@color/text_muted"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Bottom row: payment status + Pay Now if unpaid -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvApptPaymentStatus"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvPayNow"
            android:text="Tap to Pay"
            android:textSize="12sp"
            android:textColor="@color/status_pending"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

</LinearLayout>