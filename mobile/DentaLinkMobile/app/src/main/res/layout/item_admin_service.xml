<?xml version="1.0" encoding="utf-8"?>
<!-- Admin service card — mirrors the patient item_service.xml layout/proportions -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:layout_marginStart="@dimen/screen_padding"
    android:layout_marginEnd="@dimen/screen_padding"
    android:layout_marginBottom="16dp"
    android:elevation="3dp"
    android:clipToOutline="true"
    android:layout_width="match_parent"
    android:layout_height="130dp">

    <ImageView
        android:id="@+id/ivServiceImage"
        android:layout_width="110dp"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@color/primary_container"
        android:src="@android:drawable/ic_menu_gallery" />

    <LinearLayout
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvServiceName"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvServiceDescription"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <!-- Price + Edit pill row -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvServicePrice"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <!-- "Edit" admin action pill -->
            <TextView
                android:text="Edit"
                android:textSize="11sp"
                android:textColor="@color/primary_dark"
                android:textStyle="bold"
                android:background="@drawable/bg_status_badge"
                android:backgroundTint="@color/primary_container"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
