<?xml version="1.0" encoding="utf-8"?>
<!--
    Dashboard hero card background.
    Primary teal → secondary mint gradient, left-to-right.
    Matches web .dashboard-hero gradient-primary color.
    16dp corner radius matches card_radius.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="@color/primary"
        android:endColor="@color/secondary"
        android:angle="0" />
    <corners android:radius="@dimen/hero_radius" />
</shape>
