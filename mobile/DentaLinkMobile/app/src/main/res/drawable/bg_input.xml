<?xml version="1.0" encoding="utf-8"?>
<!--
    Input field background with border.
    Focused: white fill + 2dp primary border (matches web focus ring).
    Default: surface_variant fill + 1dp gray border.
    Usage: android:background="@drawable/bg_input"
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state — white bg + primary teal border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <stroke
                android:width="2dp"
                android:color="@color/input_border_focus" />
            <corners android:radius="@dimen/input_radius" />
        </shape>
    </item>

    <!-- Default state — light gray bg + subtle border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_variant" />
            <stroke
                android:width="1dp"
                android:color="@color/input_border" />
            <corners android:radius="@dimen/input_radius" />
        </shape>
    </item>

</selector>
