<?xml version="1.0" encoding="utf-8"?>
<!--
    Navigation drawer header background.
    Primary teal → secondary mint gradient, left-to-right.
    No corner radius — header fills edge-to-edge at top of drawer.
    Applied to nav_header_patient.xml and nav_header_admin.xml root.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="@color/primary"
        android:endColor="@color/secondary"
        android:angle="0" />
</shape>
