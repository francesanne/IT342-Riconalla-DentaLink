spring.application.name=backend
server.servlet.context-path=/api/v1

spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

supabase.url=${SUPABASE_URL}
supabase.key=${SUPABASE_KEY}

spring.datasource.hikari.data-source-properties.prepareThreshold=0
spring.jpa.properties.hibernate.jdbc.lob.non_contextual_creation=true
spring.datasource.hikari.auto-commit=true

# Frontend base URL used in email CTAs — set to deployed Vercel URL in production
# APP_BASE_URL=https://your-frontend.vercel.app
dentalink.app.base-url=${APP_BASE_URL:http://localhost:5173}

# Google OAuth Web Client ID — SDD §3.2 (credentials in environment variables only)
# Set GOOGLE_CLIENT_ID to the Web client ID from Google Cloud Console (OAuth 2.0 credentials)
google.client-id=${GOOGLE_CLIENT_ID}